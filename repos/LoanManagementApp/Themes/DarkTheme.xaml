<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         DARK THEME | گہرا تھیم
         LoanManagementApp - Dark Color Palette
    ════════════════════════════════════════════════════════════════ -->

    <!-- ── Background Colors | پس منظر رنگ ── -->
    <SolidColorBrush x:Key="AppBackgroundBrush"        Color="#0F1117"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"    Color="#090C14"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"       Color="#1A1D2E"/>
    <SolidColorBrush x:Key="InputBackgroundBrush"      Color="#252840"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"     Color="#13162A"/>
    <SolidColorBrush x:Key="TableRowAltBrush"          Color="#1E2235"/>
    <SolidColorBrush x:Key="TableHeaderBrush"          Color="#252840"/>
    <SolidColorBrush x:Key="HoverBrush"                Color="#1E2748"/>
    <SolidColorBrush x:Key="SelectedRowBrush"          Color="#1E3A5F"/>
    <SolidColorBrush x:Key="DialogBackgroundBrush"     Color="#1A1D2E"/>

    <!-- ── Primary Brand Colors | بنیادی رنگ ── -->
    <SolidColorBrush x:Key="PrimaryBrush"              Color="#3F51B5"/>
    <SolidColorBrush x:Key="PrimaryLightBrush"         Color="#5C6BC0"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush"          Color="#283593"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush"    Color="#FFFFFF"/>

    <!-- ── Accent Colors | ہائی لائٹ رنگ ── -->
    <SolidColorBrush x:Key="AccentBrush"               Color="#448AFF"/>
    <SolidColorBrush x:Key="AccentLightBrush"          Color="#82B1FF"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"     Color="#FFFFFF"/>

    <!-- ── Text Colors | متن رنگ ── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"          Color="#E8EAF6"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"        Color="#9FA8DA"/>
    <SolidColorBrush x:Key="TextMutedBrush"            Color="#5C6BC0"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnSidebarBrush"        Color="#C5CAE9"/>
    <SolidColorBrush x:Key="TextOnSidebarMutedBrush"   Color="#7986CB"/>
    <SolidColorBrush x:Key="LabelTextBrush"            Color="#B0BEC5"/>

    <!-- ── Border Colors | کنارہ رنگ ── -->
    <SolidColorBrush x:Key="BorderBrush"               Color="#2A2D45"/>
    <SolidColorBrush x:Key="BorderLightBrush"          Color="#1E2235"/>
    <SolidColorBrush x:Key="BorderFocusBrush"          Color="#448AFF"/>
    <SolidColorBrush x:Key="DividerBrush"              Color="#2A2D45"/>

    <!-- ── Status Colors | حیثیت رنگ ── -->
    <SolidColorBrush x:Key="SuccessBrush"              Color="#2E7D32"/>
    <SolidColorBrush x:Key="SuccessLightBrush"         Color="#1B3A1E"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush"    Color="#A5D6A7"/>

    <SolidColorBrush x:Key="DangerBrush"               Color="#C62828"/>
    <SolidColorBrush x:Key="DangerLightBrush"          Color="#3B1212"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"     Color="#EF9A9A"/>

    <SolidColorBrush x:Key="WarningBrush"              Color="#E65100"/>
    <SolidColorBrush x:Key="WarningLightBrush"         Color="#3E1A00"/>
    <SolidColorBrush x:Key="WarningForegroundBrush"    Color="#FFCC80"/>

    <SolidColorBrush x:Key="InfoBrush"                 Color="#0277BD"/>
    <SolidColorBrush x:Key="InfoLightBrush"            Color="#0A2540"/>
    <SolidColorBrush x:Key="InfoForegroundBrush"       Color="#81D4FA"/>

    <!-- ── Dashboard Card Colors | ڈیش بورڈ کارڈ رنگ ── -->
    <SolidColorBrush x:Key="Card1Brush"                Color="#1A237E"/>
    <SolidColorBrush x:Key="Card2Brush"                Color="#004D40"/>
    <SolidColorBrush x:Key="Card3Brush"                Color="#880E4F"/>
    <SolidColorBrush x:Key="Card4Brush"                Color="#BF360C"/>

    <!-- ── Shadow / Overlay | سایہ ── -->
    <SolidColorBrush x:Key="ShadowBrush"               Color="#40000000"/>
    <SolidColorBrush x:Key="OverlayBrush"              Color="#99000000"/>

    <!-- ── Sidebar Item Hover | سائیڈ بار آئٹم ہور ── -->
    <SolidColorBrush x:Key="SidebarHoverBrush"         Color="#1E2748"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"        Color="#2A3560"/>
    <SolidColorBrush x:Key="SidebarActiveIndicator"    Color="#448AFF"/>

    <!-- ── Progress Bar | پیشرفت بار ── -->
    <SolidColorBrush x:Key="ProgressBackgroundBrush"   Color="#1E2748"/>
    <SolidColorBrush x:Key="ProgressFillBrush"         Color="#448AFF"/>

    <!-- ── ScrollBar | اسکرول بار ── -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush"       Color="#3F51B5"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush"       Color="#1A1D2E"/>

</ResourceDictionary>
