<Window x:Class="LoanManagementApp.Views.Dialogs.AddLoanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
        Title="Add Loan | نیا قرض شامل کریں"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <!-- ═══════════════════════════════════════════════════════════
         ADD LOAN DIALOG | قرض شامل ڈائیلاگ
         No LetterSpacing / CharacterSpacing used
    ════════════════════════════════════════════════════════════════ -->


    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.DataContext>
        <vm:LoanViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer Buttons -->
        </Grid.RowDefinitions>

        <!-- ── TITLE BAR | عنوان بار ──────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="24,16">
            <StackPanel>
                <TextBlock Text="➕ Add New Loan | نیا قرض شامل کریں"
                           FontSize="{DynamicResource FontSizeLarge}"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding CustomerName, StringFormat=Customer: {0} | قرض دار: {0}}"
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── CONTENT | مواد ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      Style="{DynamicResource AppScrollViewerStyle}"
                      MaxHeight="500">
            <StackPanel Margin="24,20,24,0">

                <!-- ── EXISTING LOAN MERGE NOTICE | موجودہ قرض ضم نوٹس ── -->
                <Border Visibility="{Binding MergeInfoVisible,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource WarningLightBrush}"
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="16,12"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚠️ Existing Active Loan Found | موجودہ فعال قرض ملا"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningForegroundBrush}"/>
                        <TextBlock Text="{Binding MergeInfoDisplay}"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{DynamicResource WarningForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding MergedTotalDisplay}"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningForegroundBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── LOAN AMOUNT | قرض کی رقم ───────────────────── -->
                <TextBlock Text="Loan Amount (PKR) | قرض کی رقم"
                           Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="TxtTotalAmount"
                         Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource AppTextBoxStyle}"
                         Margin="0,0,0,14"/>

                <!-- ── TOTAL INSTALLMENTS | کل اقساط ─────────────── -->
                <TextBlock Text="Total Installments | کل اقساط کی تعداد"
                           Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="TxtTotalInstallments"
                         Text="{Binding TotalInstallments, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource AppTextBoxStyle}"
                         Margin="0,0,0,14"/>
                <TextBlock Text="(If active loan exists, set 0 to keep same number of remaining installments)"
                           FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,-8,0,14"
                           Visibility="{Binding HasExistingLoan, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- ── PER INSTALLMENT AMOUNT | فی قسط رقم ──────── -->
                <TextBlock Text="Per Installment Amount (PKR) | فی قسط رقم"
                           Style="{DynamicResource FormLabelStyle}"/>
                <Border Background="{DynamicResource TableHeaderBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="{DynamicResource PaddingInput}"
                        Margin="0,0,0,14">
                    <TextBlock Text="{Binding InstallmentAmount, StringFormat={}{0:N0} PKR (auto-calculated | خودکار حساب)}"
                               FontSize="{DynamicResource FontSizeMedium}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Border>

                <!-- ── DATES ROW | تاریخیں ──────────────────────── -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start Date | شروع کی تاریخ"
                                   Style="{DynamicResource FormLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding StartDate}"
                                    Style="{StaticResource AppDatePickerStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="End Date | آخری تاریخ"
                                   Style="{DynamicResource FormLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding EndDate}"
                                    Style="{StaticResource AppDatePickerStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- ── NOTES | نوٹس ──────────────────────────────── -->
                <TextBlock Text="Notes / Remarks | نوٹس / ریمارکس (Optional | اختیاری)"
                           Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="TxtNotes"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource AppTextBoxStyle}"
                         Height="72"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         Margin="0,0,0,14"/>

                <!-- ── STATUS MESSAGE | حیثیت پیغام ─────────────── -->
                <Border Visibility="{Binding HasStatusMessage,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{Binding IsStatusSuccess,
                            Converter={StaticResource BoolToStatusBackgroundConverter}}"
                        BorderBrush="{Binding IsStatusSuccess,
                            Converter={StaticResource BoolToStatusBorderConverter}}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="14,10"
                        Margin="0,0,0,14">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{Binding IsStatusSuccess,
                                   Converter={StaticResource BoolToStatusForegroundConverter}}"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── FOOTER BUTTONS | بٹنز ─────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Busy Indicator | مصروف اشارہ -->
                <TextBlock Grid.Column="0"
                           Text="⏳ Saving... | محفوظ ہو رہا ہے..."
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsBusy,
                               Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Grid.Column="2"
                        Content="✖ Cancel | منسوخ"
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        IsEnabled="{Binding IsNotBusy}"
                        x:Name="BtnCancel"
                        MinWidth="110"/>

                <Button Grid.Column="4"
                        Content="💾 Save Loan | قرض محفوظ کریں"
                        Command="{Binding SaveCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        x:Name="BtnSave"
                        MinWidth="150"/>
            </Grid>
        </Border>
    </Grid>
</Window>