<Window x:Class="LoanManagementApp.Views.Dialogs.ForgotPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password | پاس ورڈ ری سیٹ"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="24,16">
			<TextBlock Text="🔓 Reset Password | پاس ورڈ ری سیٹ کریں"
                       FontSize="{DynamicResource FontSizeLarge}"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,24,24,16">

            <!-- Step 1: Username -->
            <StackPanel x:Name="Step1Panel">
                <TextBlock Text="Enter your username | اپنا صارف نام درج کریں"
                           Style="{DynamicResource FormLabelStyle}"/>
                <TextBox x:Name="TxtUsername"
                         Style="{DynamicResource AppTextBoxStyle}"
                         Margin="0,4,0,16"/>
                <Button x:Name="BtnVerifyUser"
                        Content="🔍 Verify | تصدیق کریں"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Step 2: Recovery Options (initially hidden) -->
            <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                <TextBlock Text="Select recovery method | بحالی کا طریقہ منتخب کریں"
                           Style="{DynamicResource FormLabelStyle}"
                           Margin="0,0,0,12"/>

                <RadioButton x:Name="RbSecurityQuestion"
                             GroupName="RecoveryMethod"
                             Content="Answer Security Question | حفاظتی سوال کا جواب"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,0,10"/>

                <RadioButton x:Name="RbPin"
                             GroupName="RecoveryMethod"
                             Content="Use PIN Code | پن کوڈ استعمال کریں"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,0,16"/>

                <!-- Security Question Panel -->
                <StackPanel x:Name="SecurityQuestionPanel" Visibility="Collapsed">
                    <TextBlock x:Name="TxtSecurityQuestion"
                               Style="{DynamicResource FormLabelStyle}"
                               Text="Security Question: What is your name?"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtSecurityAnswer"
                             Style="{DynamicResource AppTextBoxStyle}"
                             Margin="0,0,0,12"
                             ToolTip="Enter your security answer"/>
                </StackPanel>

                <!-- PIN Panel -->
                <StackPanel x:Name="PinPanel" Visibility="Collapsed">
                    <TextBlock Text="Enter your PIN code | اپنا پن کوڈ درج کریں"
                               Style="{DynamicResource FormLabelStyle}"/>
                    <PasswordBox x:Name="PwdPin"
                                 Style="{DynamicResource AppPasswordBoxStyle}"
                                 Margin="0,4,0,12"/>
                </StackPanel>

                <Button x:Name="BtnProceed"
                        Content="▶ Proceed | آگے بڑھیں"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Step 3: New Password Panel (initially hidden) -->
            <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                <TextBlock Text="Set new password | نیا پاس ورڈ سیٹ کریں"
                           Style="{DynamicResource FormLabelStyle}"/>
                <PasswordBox x:Name="PwdNewPassword"
                             Style="{DynamicResource AppPasswordBoxStyle}"
                             Margin="0,4,0,10"/>
                <PasswordBox x:Name="PwdConfirmPassword"
                             Style="{DynamicResource AppPasswordBoxStyle}"
                             Margin="0,0,0,16"
                             ToolTip="Confirm new password"/>
                <Button x:Name="BtnResetPassword"
                        Content="✅ Reset Password | پاس ورڈ ری سیٹ کریں"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Status Message -->
            <Border x:Name="StatusBorder"
                    Visibility="Collapsed"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="12,8"
                    Margin="0,16,0,0">
                <TextBlock x:Name="TxtStatus"
                           FontSize="{DynamicResource FontSizeSmall}"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Footer Cancel Button -->
        <Border Grid.Row="2"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Button Content="✖ Cancel | منسوخ"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    x:Name="BtnCancel"
                    HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>