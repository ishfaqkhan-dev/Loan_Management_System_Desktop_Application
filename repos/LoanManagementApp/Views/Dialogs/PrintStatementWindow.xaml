<Window x:Class="LoanManagementApp.Views.Dialogs.PrintStatementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loan Statement | قرض اسٹیٹمنٹ"
        Width="900"
        Height="700"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBackgroundBrush}">

	<Grid>
		<!-- ═══════════════════════════════════════════
             LAYOUT: 3 Rows
             Row 0 → Title Bar
             Row 1 → Document Viewer (Scrollable)
             Row 2 → Footer Action Buttons
        ═══════════════════════════════════════════ -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ═══════════════════════════════════════════
             TITLE BAR — Header with icon and title
        ═══════════════════════════════════════════ -->
		<Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🖨️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                <TextBlock Text="Loan Statement | قرض اسٹیٹمنٹ"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
			</StackPanel>
		</Border>

		<!-- ═══════════════════════════════════════════
             DOCUMENT VIEWER — Displays the FlowDocument
             White background to simulate paper/print view
        ═══════════════════════════════════════════ -->
		<Border Grid.Row="1"
                Margin="16"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="4">
			<FlowDocumentScrollViewer x:Name="DocumentViewer"
                                      Background="White"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsToolBarVisible="False"
                                      Document="{Binding Document}"/>
		</Border>

		<!-- ═══════════════════════════════════════════
             FOOTER — Print & Close action buttons
        ═══════════════════════════════════════════ -->
		<Border Grid.Row="2"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
			<StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

				<!-- Print Button -->
				<Button Content="🖨️  Print"
                        Click="PrintButton_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Margin="0,0,10,0"
                        Padding="22,9"
                        FontSize="13"/>

				<!-- Close Button -->
				<Button Content="✖  Close"
                        Click="CloseButton_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="22,9"
                        FontSize="13"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>
