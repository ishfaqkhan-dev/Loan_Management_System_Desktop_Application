<Page x:Class="LoanManagementApp.Views.Pages.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
      Title="Account">


    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Page.DataContext>
        <vm:AccountViewModel/>
    </Page.DataContext>

    <!-- ═══════════════════════════════════════════════════════════
         ACCOUNT PAGE | اکاؤنٹ پیج (Customer List with View Button)
         Same style as CustomersPage, redirects to loan details page.
    ════════════════════════════════════════════════════════════════ -->

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Page Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER | پیج ہیڈر ──────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back | واپس"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        x:Name="BtnBack"/>

                <TextBlock Grid.Column="2"
                           Text="📋 Customer Accounts | قرض دار اکاؤنٹس"
                           FontSize="{DynamicResource FontSizeXLarge}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="3"
                        Content="🔄 Refresh | ریفریش"
                        Command="{Binding RefreshAllCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── MAIN CONTENT | مرکزی مواد ─────────────────────────── -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Search + Filter Bar -->
                <RowDefinition Height="12"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Status Message -->
                <RowDefinition Height="*"/>
                <!-- Customers Table -->
            </Grid.RowDefinitions>

            <!-- ── SEARCH + FILTER BAR | تلاش اور فلٹر بار ─────────── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box with Placeholder | تلاش باکس -->
                    <Grid Grid.Column="0">
                        <!-- Actual input — Padding="38,0,8,0" leaves room for icon on left -->
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}"
                                 Padding="38,0,8,0"
                                 Height="38"/>
                        <!-- Placeholder row: icon pinned left, text after it — hidden when typing -->
                        <StackPanel Orientation="Horizontal"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="🔍"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,20,0"/>
                            <TextBlock Text="Search by name, phone, account... | نام، فون، کھاتہ سے تلاش کریں"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Active Only Filter | صرف فعال -->
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding ShowActiveOnly}"
                              Content="Active Only | صرف فعال"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center"/>

                    <!-- Overdue Only Filter | صرف میعاد ختم -->
                    <CheckBox Grid.Column="4"
                              IsChecked="{Binding ShowOverdueOnly}"
                              Content="Overdue Only | صرف میعاد ختم"
                              Foreground="{DynamicResource DangerForegroundBrush}"
                              VerticalAlignment="Center"/>

                    <!-- Clear Filters Button | فلٹر صاف -->
                    <Button Grid.Column="6"
                            Content="✖ Clear | صاف"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Height="36"
                            MinWidth="100"
                            Padding="10,0"/>
                </Grid>
            </Border>

            <!-- ── STATUS MESSAGE | اسٹیٹس پیغام ─────────────────────── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="12,8"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSizeNormal}"/>
            </Border>

            <!-- ── CUSTOMERS TABLE | قرض داروں کی جدول ────────────── -->
            <Border Grid.Row="3"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Table Header -->
                        <RowDefinition Height="*"/>
                        <!-- Table Rows -->
                    </Grid.RowDefinitions>

                    <!-- Table Column Headers (same widths as ListView data rows) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource TableHeaderBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="0,0,0,0">
                        <Grid Margin="16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <!-- # -->
                                <ColumnDefinition Width="180"/>
                                <!-- Name — fixed -->
                                <ColumnDefinition Width="*"/>
                                <!-- Account # — takes remaining -->
                                <ColumnDefinition Width="140"/>
                                <!-- Phone -->
                                <ColumnDefinition Width="110"/>
                                <!-- Total Loan -->
                                <ColumnDefinition Width="110"/>
                                <!-- Remaining -->
                                <ColumnDefinition Width="90"/>
                                <!-- Status -->
                                <ColumnDefinition Width="110"/>
                                <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="1" Text="Customer | قرض دار"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Account | کھاتہ"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="Phone | فون"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="Total | کل رقم"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="5" Text="Remaining | باقی"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="6" Text="Status | حیثیت"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="7" Text="Actions | اقدامات"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Table Data (ListView matching CustomersPage style exactly) -->
                    <ListView Grid.Row="1"
                              x:Name="AccountsListView"
                              ItemsSource="{Binding FilteredCustomers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              Style="{StaticResource AppListViewStyle}"
                              AlternationCount="{Binding FilteredCustomers.Count}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem"
                                   BasedOn="{StaticResource AppListViewItemStyle}">
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row Number | نمبر (1-based via AlternationIndex) -->
                                    <TextBlock Grid.Column="0"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="(ItemsControl.AlternationIndex)"
                                                     RelativeSource="{RelativeSource AncestorType=ListViewItem}"
                                                     Converter="{StaticResource IndexConverter}"/>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <!-- Customer Name + Father Name | نام + باپ کا نام -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{DynamicResource FontSizeNormal}"/>
                                        <TextBlock Text="{Binding FatherName, StringFormat=S/O {0}}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="{DynamicResource FontSizeTiny}"/>
                                    </StackPanel>

                                    <!-- Account Number | کھاتہ نمبر -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AccountNumber}"
                                               Foreground="{DynamicResource AccentLightBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               VerticalAlignment="Center"/>

                                    <!-- Phone | فون -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding PhoneNumber1}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               VerticalAlignment="Center"/>

                                    <!-- Total Loan | کل قرض -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding TotalLoanAmount, StringFormat={}{0:N0}}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               VerticalAlignment="Center"/>

                                    <!-- Remaining Balance | باقی رقم -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding RemainingBalance, StringFormat={}{0:N0}}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessForegroundBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerForegroundBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Status Badge | حیثیت بیج -->
                                    <Border Grid.Column="6"
        CornerRadius="{DynamicResource RadiusPill}"
        Padding="8,3"
        HorizontalAlignment="Left"
        VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                                <Style.Triggers>
                                                    <!-- Closed (fully paid) -->
                                                    <DataTrigger Binding="{Binding RemainingBalance}" Value="0">
                                                        <Setter Property="Background" Value="{DynamicResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <!-- Overdue -->
                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="✅ Active"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessForegroundBrush}"/>
                                                    <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                                                    <Style.Triggers>
                                                        <!-- Closed (fully paid) -->
                                                        <DataTrigger Binding="{Binding RemainingBalance}" Value="0">
                                                            <Setter Property="Text" Value="✅ Closed"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource InfoForegroundBrush}"/>
                                                        </DataTrigger>
                                                        <!-- Overdue -->
                                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                            <Setter Property="Text" Value="⚠️ Overdue"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerForegroundBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- View Account Button | اکاؤنٹ دیکھیں -->
                                    <StackPanel Grid.Column="7"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="👁 View Account"
                                                Style="{StaticResource SmallPrimaryButtonStyle}"
                                                Command="{Binding DataContext.ViewAccountCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,4,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- ── EMPTY STATE | خالی حیثیت ──────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Visibility="{Binding FilteredCustomers.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="40">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="No accounts found | کوئی اکاؤنٹ نہیں ملا"
                               FontSize="{DynamicResource FontSizeMedium}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Page>
