<Page x:Class="LoanManagementApp.Views.Pages.CustomerDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
      Title="Customer Detail">


    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Page.DataContext>
        <vm:CustomerDetailViewModel/>
    </Page.DataContext>

    <!-- ═══════════════════════════════════════════════════════════
         CUSTOMER DETAIL PAGE | قرض دار تفصیل پیج
         Add or Edit a customer profile with full form
    ════════════════════════════════════════════════════════════════ -->

    <ScrollViewer Style="{DynamicResource AppScrollViewerStyle}">
        <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Page Header -->
                <RowDefinition Height="20"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Status Bar -->
                <RowDefinition Height="12"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Personal Info Card -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Contact Info Card -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Loan Dates Card -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Loan Amount & Installments Card -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Modify Remaining Installments Card (only for edit, active loan) -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Notes Card -->
                <RowDefinition Height="24"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Action Buttons -->
            </Grid.RowDefinitions>

            <!-- ── PAGE HEADER | پیج ہیڈر ────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back | واپس"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        x:Name="BtnBack"
                        VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="{DynamicResource FontSizeXLarge}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Fill in all required fields | تمام ضروری خانے بھریں"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ── STATUS BAR | اسٹیٹس بار ──────────────────────────── -->
            <Border Grid.Row="2"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="16,10"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="{DynamicResource FontSizeNormal}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SuccessForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerForegroundBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- ── PERSONAL INFORMATION CARD | ذاتی معلومات کارڈ ───── -->
            <Border Grid.Row="4"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Personal Info | ذاتی معلومات"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Full Name * | پورا نام (ضروری)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Father Name | والد کا نام"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding FatherName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Emirates ID / CNIC | شناختی کارڈ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EmiratesIdOrCnic, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Account Number | کھاتہ نمبر"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource TableHeaderBrush}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsActive}"
                                  Content="Active Customer | فعال قرض دار"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── CONTACT INFORMATION CARD | رابطہ معلومات کارڈ ────── -->
            <Border Grid.Row="6"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="📞" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Contact Info | رابطہ معلومات"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phone 1 * | فون ۱ (ضروری)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding PhoneNumber1, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Phone 2 | فون ۲"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding PhoneNumber2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Phone 3 | فون ۳"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding PhoneNumber3, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Address | پتہ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="City | شہر"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── LOAN DATES CARD | قرض تاریخیں کارڈ ──────────────── -->
            <Border Grid.Row="8"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="📅" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Loan Dates | قرض کی تاریخیں"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Loan Start Date | قرض شروع کی تاریخ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding LoanStartDate}"
                                        Style="{StaticResource AppDatePickerStyle}"
                                        Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loan End Date | قرض ختم کی تاریخ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding LoanEndDate}"
                                        Style="{StaticResource AppDatePickerStyle}"
                                        Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── LOAN AMOUNT & INSTALLMENTS CARD | قرض کی رقم اور اقساط ── -->
            <Border Grid.Row="10"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="💰" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Loan Details | قرض کی تفصیلات"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Loan Amount (PKR) * | قرض کی رقم (ضروری)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox x:Name="TxtLoanAmount"
                                     Text="{Binding LoanAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Total Installments * | کل اقساط (ضروری)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox x:Name="TxtTotalInstallments"
                                     Text="{Binding TotalInstallments, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Per Installment Amount (PKR) | فی قسط رقم"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <Border Background="{DynamicResource TableHeaderBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RadiusMedium}"
                                    Padding="{DynamicResource PaddingInput}"
                                    Height="42">
                                <TextBlock Text="{Binding CalculatedInstallmentAmount, StringFormat={}{0:N0} PKR}"
                                           FontSize="{DynamicResource FontSizeMedium}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── MODIFY REMAINING INSTALLMENTS CARD | باقی اقساط میں تبدیلی ── -->
            <Border Grid.Row="12"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}"
                    Visibility="{Binding HasActiveLoan, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Modify Remaining Installments | باقی اقساط میں تبدیلی"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="New Remaining Installments | نئی باقی اقساط"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox x:Name="TxtNewRemainingInstallments"
                                     Text="{Binding NewRemainingInstallments, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="New Per Installment Amount (PKR) | نئی فی قسط رقم (auto-calculated)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <Border Background="{DynamicResource TableHeaderBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RadiusMedium}"
                                    Padding="{DynamicResource PaddingInput}"
                                    Height="42">
                                <TextBlock Text="{Binding NewInstallmentAmount, StringFormat={}{0:N0} PKR}"
                                           FontSize="{DynamicResource FontSizeMedium}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── NOTES CARD | نوٹس کارڈ ───────────────────────────── -->
            <Border Grid.Row="14"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="📝" FontSize="18" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Notes | نوٹس"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBox Grid.Row="2"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource AppTextBoxStyle}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- ── ACTION BUTTONS | اقدامات بٹن ────────────────────── -->
            <Grid Grid.Row="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⏳ Saving... | محفوظ ہو رہا ہے..."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeNormal}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✖ Cancel | منسوخ"
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"/>

                <Button Grid.Column="3"
                        Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>