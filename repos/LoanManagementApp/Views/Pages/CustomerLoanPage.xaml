<Page x:Class="LoanManagementApp.Views.Pages.CustomerLoanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
      Title="Customer Loan Details">


    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Page.DataContext>
        <vm:CustomerLoanViewModel/>
    </Page.DataContext>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER | پیج ہیڈر ──────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back | واپس"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        x:Name="BtnBack"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding PageTitle}"
                           FontSize="{DynamicResource FontSizeXLarge}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🖨️ Print Statement | پرنٹ اسٹیٹمنٹ"
                            Command="{Binding PrintStatementCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"
                            Height="36"
                            Padding="12,0"/>
                    <Button Content="🔄 Refresh | ریفریش"
                            Command="{Binding RefreshCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Height="36"
                            Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── MAIN CONTENT | مرکزی مواد ──────────────────────────── -->
        <ScrollViewer Grid.Row="1" Style="{DynamicResource AppScrollViewerStyle}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── LOAN SELECTION BOX (only label + combobox, right-aligned) ───────── -->
                <Border Grid.Row="0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="12,12"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="📋 Select Loan | قرض منتخب کریں:"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,12,0"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CustomerLoans}"
                                  SelectedItem="{Binding SelectedLoan}"
                                  Style="{DynamicResource AppComboBoxStyle}"
                                  Width="300"
                                  Height="36"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── ACTIVE LOAN DETAILS BOX (with buttons) ───────────── -->
                <Border Grid.Row="1"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="12"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ActiveLoanDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding ActiveLoanDates}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="{Binding AddLoanButtonText}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding AddMoreLoanCommand}"
                                    Height="36"
                                    Padding="12,0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <Button Content="💵 Record Custom Payment | ادائیگی درج کریں"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Command="{Binding RecordCustomPaymentCommand}"
                                    Height="36"
                                    Padding="12,0"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SUMMARY CARDS (4 cards) | خلاصہ کارڈز ─────────── -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Loan Card -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource Card1Brush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="💰 Total Loan" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding TotalLoanDisplay}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Paid Card -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource Card2Brush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="✅ Total Paid" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding TotalPaidDisplay}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Remaining Card -->
                    <Border Grid.Column="4"
                            Background="{DynamicResource Card3Brush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="⏳ Remaining" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding TotalRemainingDisplay}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Status Card -->
                    <Border Grid.Column="6"
                            Background="{DynamicResource Card4Brush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="📋 Status" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding LoanStatusText}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── PROGRESS BAR | پیشرفت بار ──────────────────────── -->
                <Border Grid.Row="3"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="12"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Payment Progress | ادائیگی کی پیشرفت" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProgressPercentage, StringFormat={}{0:F1}%}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>
                        <ProgressBar Grid.Row="2"
                                     Value="{Binding ProgressPercentage, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="10">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid>
                                        <Border x:Name="PART_Track" Background="#2A2A3A" CornerRadius="5"/>
                                        <Border x:Name="PART_Indicator" Background="{DynamicResource AccentBrush}" CornerRadius="5" HorizontalAlignment="Left"/>
                                    </Grid>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </Grid>
                </Border>

                <!-- ── INSTALLMENTS GRID | اقساط کی گرڈ ───────────────── -->
                <Border Grid.Row="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="12"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📋 Installments | اقساط" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Installments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="150" Height="105" Margin="6"
                                            CornerRadius="8" Background="{Binding BackgroundColor}" BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding InstallmentNumber, StringFormat=Installment {0}}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding TextColor}" HorizontalAlignment="Center" Margin="4,8,4,4"/>
                                            <TextBlock Grid.Row="1" Text="{Binding AmountDisplay}" FontSize="15" FontWeight="Bold" Foreground="{Binding TextColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button Grid.Row="2" Content="{Binding ButtonText}" Command="{Binding DataContext.PayInstallmentCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Style="{StaticResource SmallPrimaryButtonStyle}" Height="28" FontSize="10" Margin="8,0,8,6" Visibility="{Binding ShowPayButton}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- ── PAYMENT HISTORY (with View button, equal column widths) ── -->
                <Border Grid.Row="5"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="12"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="💳 Payment History | ادائیگی تاریخ"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Column Headers (equal star widths for all columns) -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource TableHeaderBrush}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Padding="0,6"
                                    Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#"
                                               Style="{StaticResource TableHeaderTextStyle}"
                                               Padding="8,0,0,0"
                                               TextAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="Date | تاریخ"
                                               Style="{StaticResource TableHeaderTextStyle}"
                                               Padding="8,0,0,0"
                                               TextAlignment="Left"/>
                                    <TextBlock Grid.Column="2" Text="Paid | ادا شدہ"
                                               Style="{StaticResource TableHeaderTextStyle}"
                                               TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Balance | باقی"
                                               Style="{StaticResource TableHeaderTextStyle}"
                                               TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Action"
                                               Style="{StaticResource TableHeaderTextStyle}"
                                               TextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Payment List (with View button) -->
                            <ListView Grid.Row="1"
                                      ItemsSource="{Binding PaymentHistory}"
                                      MaxHeight="250"
                                      Style="{StaticResource AppListViewStyle}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderLightBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- # -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding InstallmentNumber}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           Padding="8,0,0,0"
                                                           TextAlignment="Left"/>

                                                <!-- Date -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding PaymentDate, StringFormat=dd-MMM-yyyy}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Padding="8,0,0,0"
                                                           TextAlignment="Left"/>

                                                <!-- Paid — Right -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding PaidAmount, StringFormat={}{0:N0}}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SuccessForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"/>

                                                <!-- Balance — Right -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding RemainingBalanceAfterPayment, StringFormat={}{0:N0}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"/>

                                                <!-- View Button -->
                                                <Button Grid.Column="4"
                                                        Content="👁 View"
                                                        Style="{StaticResource SmallPrimaryButtonStyle}"
                                                        Command="{Binding DataContext.ViewPaymentDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Height="28"
                                                        MaxWidth="100"
                                                        Margin="4,0,4,0"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>