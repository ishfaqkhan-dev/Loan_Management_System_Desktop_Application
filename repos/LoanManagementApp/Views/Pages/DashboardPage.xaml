<Page x:Class="LoanManagementApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
      Title="Dashboard">


    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Page.DataContext>
        <vm:DashboardViewModel/>
    </Page.DataContext>

    <!-- ═══════════════════════════════════════════════════════════
         DASHBOARD PAGE | ڈیش بورڈ پیج
         Main summary screen with stats, chart, and overdue alerts
    ════════════════════════════════════════════════════════════════ -->

    <ScrollViewer Style="{DynamicResource AppScrollViewerStyle}" CanContentScroll="False">
        <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── HEADER | ہیڈر ──────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               FontSize="{DynamicResource FontSizeXLarge}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding TodayDisplay}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="💾 Backup Now"
                            Command="{Binding BackupNowCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>

            <!-- ── SUMMARY CARDS | خلاصہ کارڈز ─────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Card 1: Total Loaned -->
                <Border Grid.Column="0"
                        Background="{DynamicResource Card1Brush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="{DynamicResource PaddingCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="💰" FontSize="28" Foreground="White"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalLoaned, StringFormat={}{0:N0}}"
                                   FontSize="{DynamicResource FontSizeXXLarge}"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Grid.Row="4" Text="PKR | Total Loaned | کل قرض"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="#B0BEC5"/>
                    </Grid>
                </Border>
                <!-- Card 2: Total Collected -->
                <Border Grid.Column="2"
                        Background="{DynamicResource Card2Brush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="{DynamicResource PaddingCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="✅" FontSize="28" Foreground="White"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalCollected, StringFormat={}{0:N0}}"
                                   FontSize="{DynamicResource FontSizeXXLarge}"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Grid.Row="4" Text="PKR | Total Collected | کل وصول"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="#B0BEC5"/>
                    </Grid>
                </Border>
                <!-- Card 3: Total Remaining -->
                <Border Grid.Column="4"
                        Background="{DynamicResource Card3Brush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="{DynamicResource PaddingCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="⏳" FontSize="28" Foreground="White"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalRemaining, StringFormat={}{0:N0}}"
                                   FontSize="{DynamicResource FontSizeXXLarge}"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Grid.Row="4" Text="PKR | Remaining | باقی"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="#B0BEC5"/>
                    </Grid>
                </Border>
                <!-- Card 4: Overdue Count -->
                <Border Grid.Column="6"
                        Background="{DynamicResource Card4Brush}"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="{DynamicResource PaddingCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="⚠️" FontSize="28" Foreground="White"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding OverdueCount}"
                                   FontSize="{DynamicResource FontSizeXXLarge}"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Grid.Row="4" Text="Overdue Loans | میعاد ختم"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="#B0BEC5"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── STATUS BAR | اسٹیٹس بار ─────────────────────────── -->
            <Border Grid.Row="4"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="16,10"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSizeNormal}"/>
            </Border>

            <!-- ── MONTHLY COLLECTIONS CHART (with fixed Month/Year pickers) ── -->
            <Border Grid.Row="6"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}"
                    MinHeight="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title and Month/Year Pickers -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="📊 Monthly Collections (Daily Bars) | ماہانہ وصولی (روزانہ بارز)"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,4">
                            <!-- Month ComboBox -->
                            <ComboBox x:Name="MonthComboBox"
                                      Width="110"
                                      Height="35"
                                      VerticalContentAlignment="Center"
                                      SelectedIndex="{Binding SelectedMonthIndex}"
                                      MaxDropDownHeight="200"
                                      IsTextSearchEnabled="False"
                                      Style="{DynamicResource AppComboBoxStyle}">
                                <ComboBoxItem Content="January" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="February" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="March" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="April" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="May" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="June" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="July" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="August" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="September" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="October" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="November" VerticalContentAlignment="Center" Padding="8,4"/>
                                <ComboBoxItem Content="December" VerticalContentAlignment="Center" Padding="8,4"/>
                            </ComboBox>
                            <!-- Year ComboBox -->
                            <ComboBox x:Name="YearComboBox"
                                      Width="110"
                                      Height="35"
                                      Margin="8,0,8,0"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding YearsList}"
                                      SelectedItem="{Binding SelectedYear}"
                                      MaxDropDownHeight="200"
                                      IsTextSearchEnabled="False"
                                      Style="{DynamicResource AppComboBoxStyle}">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <!-- Load Button -->
                            <Button Content="⟳ Load"
                                    Command="{Binding LoadChartCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="35"
                                    Padding="12,0"
                                    MinWidth="70"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bar Chart (using ItemsControl with UniformGrid) -->
                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding MonthlyChartData}" Height="200">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="{Binding MonthlyChartData.Count}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Bar (uses dynamic height based on max amount in the month) -->
                                        <Border Grid.Row="0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource PrimaryBrush}"
                                                CornerRadius="4,4,0,0"
                                                Height="{Binding RelativeHeight}"
                                                MinHeight="0"
                                                MaxHeight="160"/>
                                        <!-- Amount label -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding AmountDisplay}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10"
                                                   Margin="0,4,0,0"/>
                                        <!-- Day label -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Month}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="10"
                                                   Margin="0,2,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="4"
                               Text="No payment data for selected month | اس مہینے میں کوئی ادائیگی نہیں"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding MonthlyChartData.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- ── OVERDUE LOANS TABLE (equal column widths) ───────── -->
            <Border Grid.Row="8"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="{DynamicResource PaddingCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="⚠️ Overdue Loans | میعاد ختم قرضے"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border Background="{DynamicResource DangerBrush}"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="8,2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverdueCount}"
                                       Foreground="White"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Table Header -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource TableHeaderBrush}"
                            CornerRadius="8"
                            Padding="0">
                        <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Customer | قرض دار"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="1" Text="Account # | کھاتہ نمبر"
                                       Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Remaining | باقی رقم"
                                       Style="{StaticResource TableHeaderTextStyle}" TextAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Overdue Days | گزرے ہوئے دن"
                                       Style="{StaticResource TableHeaderTextStyle}" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Overdue Loans List -->
                    <ListView Grid.Row="4"
                              ItemsSource="{Binding OverdueLoans}"
                              Style="{StaticResource AppListViewStyle}"
                              MaxHeight="260"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource AppListViewItemStyle}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Customer.FullName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{DynamicResource FontSizeNormal}"/>
                                        <TextBlock Text="{Binding Customer.PhoneNumber1}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="{DynamicResource FontSizeSmall}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Customer.AccountNumber}"
                                               Foreground="{DynamicResource AccentLightBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding RemainingAmount, StringFormat={}{0:N0} PKR}"
                                               Foreground="{DynamicResource WarningForegroundBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DueStatusEnglish}"
                                               Foreground="{DynamicResource DangerForegroundBrush}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Grid.Row="4"
                               Text="No overdue loans | کوئی میعاد ختم قرض نہیں"
                               FontSize="{DynamicResource FontSizeMedium}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding OverdueLoans.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>