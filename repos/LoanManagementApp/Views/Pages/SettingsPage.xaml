<Page x:Class="LoanManagementApp.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:LoanManagementApp.ViewModels"
      Title="Settings">


    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>

    <!-- ═══════════════════════════════════════════════════════════
         SETTINGS PAGE | ترتیبات پیج
         Tabs: General | Security | Backup
    ════════════════════════════════════════════════════════════════ -->

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Page Header -->
            <RowDefinition Height="*"/>
            <!-- Tab Content -->
        </Grid.RowDefinitions>

        <!-- ── PAGE HEADER | پیج ہیڈر ──────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="24,16">
            <TextBlock Text="⚙️ Settings | ترتیبات"
                       FontSize="{DynamicResource FontSizeXLarge}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <!-- ── MAIN CONTENT | مرکزی مواد ──────────────────────────── -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <!-- Tab Nav -->
                <ColumnDefinition Width="20"/>
                <!-- Gap -->
                <ColumnDefinition Width="*"/>
                <!-- Tab Content -->
            </Grid.ColumnDefinitions>

            <!-- ────────────────────────────────────────────────────────
                 LEFT NAV TABS | بائیں نیویگیشن ٹیبز
            ─────────────────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="8">
                <StackPanel>
                    <!-- General Tab -->
                    <Button Content="🏢 General | عمومی"
                            Style="{StaticResource TabNavButtonStyle}"
                            Tag="0"
                            x:Name="BtnTabGeneral"
                            Click="TabButton_Click"
                            Margin="0,4"/>

                    <!-- Security Tab -->
                    <Button Content="🔐 Security | حفاظت"
                            Style="{StaticResource TabNavButtonStyle}"
                            Tag="1"
                            x:Name="BtnTabSecurity"
                            Click="TabButton_Click"
                            Margin="0,4"/>

                    <!-- Backup Tab -->
                    <Button Content="💾 Backup | بیک اپ"
                            Style="{StaticResource TabNavButtonStyle}"
                            Tag="2"
                            x:Name="BtnTabBackup"
                            Click="TabButton_Click"
                            Margin="0,4"/>
                </StackPanel>
            </Border>

            <!-- ────────────────────────────────────────────────────────
                 RIGHT CONTENT PANELS | دائیں مواد پینلز
            ─────────────────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2" Style="{DynamicResource AppScrollViewerStyle}">
                <Grid>

                    <!-- ══ TAB 0: GENERAL SETTINGS | عمومی ترتیبات ══ -->
                    <Border x:Name="PanelGeneral"
                            Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="{DynamicResource PaddingCard}"
                            Visibility="Visible">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Section Title -->
                            <TextBlock Grid.Row="0"
                                       Text="🏢 General Settings | عمومی ترتیبات"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <!-- Company Name -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Company Name (English) | کمپنی کا نام"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource AppTextBoxStyle}"
                                         Width="400"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Company Phone -->
                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Company Phone | کمپنی فون نمبر"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource AppTextBoxStyle}"
                                         Width="300"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Save General Button -->
                            <Button Grid.Row="8"
                                    Content="💾 Save General Settings | عمومی ترتیبات محفوظ کریں"
                                    Command="{Binding SaveGeneralCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>

                    <!-- ══ TAB 1: SECURITY SETTINGS | حفاظت ترتیبات ══ -->
                    <Border x:Name="PanelSecurity"
                            Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="{DynamicResource PaddingCard}"
                            Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="🔐 Security Settings | حفاظتی ترتیبات"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- Change Password Section -->
                            <TextBlock Text="Change Password | پاس ورڈ تبدیل کریں"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Current Password | موجودہ پاس ورڈ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PbCurrentPassword"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <TextBlock Text="New Password | نیا پاس ورڈ"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PbNewPassword"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <TextBlock Text="Confirm Password | پاس ورڈ تصدیق"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PbConfirmPassword"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <Button Content="🔑 Change Password"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    x:Name="BtnChangePassword"
                                    Click="BtnChangePassword_Click"
                                    Margin="0,12,0,24"/>

                            <!-- Separator -->
                            <Separator Style="{DynamicResource DividerStyle}" Margin="0,20,0,20"/>

                            <!-- Change Username Section -->
                            <TextBlock Text="👤 Change Username | صارف نام تبدیل کریں"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="Current Password (required) | موجودہ پاس ورڈ (ضروری)"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <PasswordBox x:Name="PbCurrentForUsername"
                                             Style="{DynamicResource AppPasswordBoxStyle}"
                                             Width="340"
                                             HorizontalAlignment="Left"
                                             Margin="0,4,0,12"/>

                                <TextBlock Text="New Username | نیا صارف نام"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <TextBox x:Name="TxtNewUsername"
                                         Style="{DynamicResource AppTextBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                                <Button Content="💾 Change Username"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        x:Name="BtnChangeUsername"
                                        HorizontalAlignment="Left"
                                        Width="220"/>
                            </StackPanel>

                            <Separator Style="{DynamicResource DividerStyle}" Margin="0,0,0,24"/>

                            <!-- Security Question Section -->
                            <TextBlock Text="🔐 Security Question | حفاظتی سوال"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Current Password (required)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PbCurrentForSecurity"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <TextBlock Text="New Security Question"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox x:Name="TxtNewSecurityQuestion"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Width="400"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,12"/>

                            <TextBlock Text="Answer"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <TextBox x:Name="TxtNewSecurityAnswer"
                                     Style="{DynamicResource AppTextBoxStyle}"
                                     Width="400"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,12"/>

                            <Button Content="💾 Save Security Question"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    x:Name="BtnSaveSecurityQuestion"
                                    HorizontalAlignment="Left"
                                    Width="220"
                                    Margin="0,12,0,24"/>

                            <Separator Style="{DynamicResource DividerStyle}" Margin="0,0,0,24"/>

                            <!-- PIN Section -->
                            <TextBlock Text="🔢 PIN Code | پن کوڈ"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Current Password (required)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PbCurrentForPin"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <TextBlock Text="New PIN (4-6 digits)"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PwdNewPin"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <TextBlock Text="Confirm PIN"
                                       Style="{DynamicResource FormLabelStyle}"/>
                            <PasswordBox x:Name="PwdConfirmPin"
                                         Style="{DynamicResource AppPasswordBoxStyle}"
                                         Width="340"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,12"/>

                            <Button Content="💾 Save PIN"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    x:Name="BtnSavePin"
                                    HorizontalAlignment="Left"
                                    Width="220"
                                    Margin="0,12,0,0"/>

                        </StackPanel>
                    </Border>

                    <!-- ══ TAB 2: BACKUP SETTINGS | بیک اپ ترتیبات ══ -->
                    <Border x:Name="PanelBackup"
                            Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="{DynamicResource RadiusLarge}"
                            Padding="{DynamicResource PaddingCard}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="💾 Backup Settings | بیک اپ ترتیبات"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <!-- Backup Path -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Backup Folder Path | بیک اپ فولڈر"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding BackupFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource AppTextBoxStyle}"/>
                                    <Button Grid.Column="2"
                                            Content="📁 Browse | براؤز"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            x:Name="BtnBrowseBackup"
                                            Click="BtnBrowseBackup_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- Auto Backup Toggle -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto Backup | خودکار بیک اپ"
                                               Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBlock Text="Automatically backup daily | روزانہ خودکار بیک اپ"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                             IsChecked="{Binding AutoBackupEnabled}"
                                             Style="{StaticResource AppToggleStyle}"
                                             VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Keep backups count -->
                            <StackPanel Grid.Row="6">
                                <TextBlock Text="Keep Last N Backups | آخری کتنے بیک اپ رکھیں"
                                           Style="{DynamicResource FormLabelStyle}"/>
                                <TextBox Text="{Binding MaxBackupFilesToKeep, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource AppTextBoxStyle}"
                                         Width="100"
                                         HorizontalAlignment="Left"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Save + Backup Now -->
                            <StackPanel Grid.Row="8" Orientation="Horizontal">
                                <Button Content="💾 Save Backup Settings | محفوظ کریں"
                                        Command="{Binding SaveBackupSettingsCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="0,0,12,0"/>
                                <Button Content="▶ Backup Now | ابھی بیک اپ کریں"
                                        Command="{Binding BackupNowCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"/>
                            </StackPanel>

                            <!-- Last Backup Info -->
                            <Border Grid.Row="10"
                                    Background="{DynamicResource InfoLightBrush}"
                                    CornerRadius="{DynamicResource RadiusMedium}"
                                    Padding="12,8">
                                <TextBlock Text="{Binding LastBackupDisplay}"
                                           Foreground="{DynamicResource InfoForegroundBrush}"
                                           FontSize="{DynamicResource FontSizeNormal}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Status Bar hidden — popup use ho raha hai | اسٹیٹس بار چھپی ہوئی — پاپ اپ استعمال ہو رہا ہے -->
                    <Border VerticalAlignment="Bottom"
                            CornerRadius="{DynamicResource RadiusMedium}"
                            Padding="12,8"
                            Margin="0,8,0,0"
                            Visibility="Collapsed">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="{DynamicResource FontSizeNormal}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerForegroundBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>